# SubDL (opcional)
SUBDL_API_KEY=tu_api_key_de_subdl
SUBDL_USER_AGENT=StremioSubAddonES/1.0

# NVIDIA AI (traducción) - obligatorio
# Crear cuenta gratis en https://build.nvidia.com → API Keys
NVIDIA_API_KEY=tu_api_key_de_nvidia
NVIDIA_MODEL=nvidia/riva-translate-4b-instruct-v1.1

# Subsource (opcional)
SUBSOURCE_API_KEY=tu_api_key_de_subsource

# Puerto del servidor
PORT=7000

# URL base (para hosting cloud, ej: https://stremio-sub-es.onrender.com)
# Si no se define, usa http://127.0.0.1:PORT
BASE_URL=
